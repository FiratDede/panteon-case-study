generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WeeklyLeaderboardStatus {
  ACTIVE
  FINALIZING
  FINALIZED
}

model Player {
  id                  Int                      @id @default(autoincrement())
  playerName          String                   @unique @map("player_name")
  totalMoney          BigInt                   @default(0) @map("total_money")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  leaderboardWinners  WeeklyLeaderboardWinner[]

  @@map("players")
}

model WeeklyLeaderboard {
  id          String                    @id @default(uuid())
  weekId      String                    @unique @map("week_id")
  startsAt    DateTime                  @map("starts_at")
  endsAt      DateTime                  @map("ends_at")
  prizePool   BigInt                    @default(0) @map("prize_pool")
  status      WeeklyLeaderboardStatus   @default(ACTIVE)
  finalizedAt DateTime?                 @map("finalized_at")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  winners     WeeklyLeaderboardWinner[]

  @@map("weekly_leaderboards")
}

model WeeklyLeaderboardWinner {
  id                    String              @id @default(uuid())
  weeklyLeaderboardId   String              @map("weekly_leaderboard_id")
  playerId              Int                 @map("player_id")
  rank                  Int
  score                 BigInt
  rewardAmount          BigInt              @map("reward_amount")
  paidAt                DateTime            @default(now()) @map("paid_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  player                Player              @relation(fields: [playerId], references: [id])
  weeklyLeaderboard     WeeklyLeaderboard   @relation(fields: [weeklyLeaderboardId], references: [id])

  @@unique([weeklyLeaderboardId, playerId])
  @@unique([weeklyLeaderboardId, rank])
  @@index([playerId])
  @@map("weekly_leaderboard_winners")
}
