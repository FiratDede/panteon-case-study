{
  "name": "panteon-case-study",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace apps/server run dev",
    "dev:client": "npm --workspace apps/client run dev",
    "preview:client": "npm --workspace apps/client run preview -- --host 0.0.0.0 --port 5173",
    "build": "npm --workspace apps/server run build && npm --workspace apps/client run build",
    "test": "npm --workspace apps/server run test",
    "typecheck": "npm --workspace apps/server run typecheck && npm --workspace apps/client run typecheck",
    "prisma:generate": "npm --workspace apps/server run prisma:generate",
    "prisma:migrate": "npm --workspace apps/server run prisma:migrate",
    "seed": "npm --workspace apps/server run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
